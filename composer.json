{
    "name": "amsat/satellite-status",
    "description": "AMSAT Satellite Status Page and API",
    "type": "project",
    "license": "proprietary",
    "require-dev": {
        "guzzlehttp/guzzle": "^7.8",
        "phpunit/phpunit": "^10.5",
        "symfony/finder": "^7.0",
        "symfony/yaml": "^7.0",
        "zircote/swagger-php": "^5.8"
    },
    "autoload-dev": {
        "psr-4": {
            "AmsatStatus\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "openapi": "openapi --bootstrap api/v1/openapi_spec.php --version 3.0.3 --format json --output api/v1/openapi.json api/v1/openapi_spec.php",
        "test": "phpunit --colors=auto"
    }
}
